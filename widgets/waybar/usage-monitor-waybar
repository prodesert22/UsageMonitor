#!/usr/bin/env python3
from __future__ import annotations

import importlib.util
import json
from pathlib import Path


def _load_run():
    module_path = Path(__file__).resolve().with_name("usage_monitor_waybar.py")
    spec = importlib.util.spec_from_file_location("usage_monitor_waybar", module_path)
    if spec is None or spec.loader is None:
        return None
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return getattr(module, "run", None)


if __name__ == "__main__":
    run = _load_run()
    if run is None:
        print(json.dumps({
            "text": "—",
            "tooltip": "UsageMonitor unavailable",
            "class": "stale",
            "percentage": 0,
            "has_errors": True,
            "providers": [],
            "updated_at": "",
        }))
    else:
        print(run())
